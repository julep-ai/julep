FROM python:3.12-slim
COPY julep-v2 /src/julep-v2
RUN pip install --no-cache-dir '/src/julep-v2[temporal,http,providers]' 'any-llm-sdk[anthropic]'
COPY session_demo.py /app/session_demo.py
COPY session_demo_worker.py /app/session_demo_worker.py
ENV PYTHONPATH=/app \
    WORKER_CONTEXT_FACTORY=session_demo_worker:make_context \
    WORKER_HEALTH_PORT=8080
ENTRYPOINT ["julep", "worker"]
