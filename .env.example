# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================
# These must be set for the application to function properly.

# Image Tags
# ----------

# Docker image tag to use for Julep services
# Use "dev" for development, or a specific version tag for production
TAG=dev

# Security
# --------

# JWT secret key for signing and verifying authentication tokens
# Used by the gateway and Hasura for token validation
# Generate with: openssl rand -base64 32
JWT_SHARED_KEY=<your_jwt_shared_key>

# API key for authenticating requests to the Agents API (server-side)
# Can be any random string you choose for access control
# Generate with: openssl rand -base64 32
AGENTS_API_KEY=<some_random_key>

# API key for Julep SDKs and CLI (client-side)
# Used by Python/Node.js SDKs and the julep CLI to authenticate with the API
# Should match AGENTS_API_KEY for self-hosted deployments
# For Julep Cloud: get from https://dashboard.julep.ai/api-keys
JULEP_API_KEY=<your_julep_api_key>

# Master encryption key for storing secrets (API keys, tokens) securely in the database
# IMPORTANT: Must be EXACTLY 32 characters long
# Generate with: openssl rand -base64 24 (produces 32 chars)
SECRETS_MASTER_KEY=<your_32_char_secrets_master_key>

# Database Passwords
# ------------------

# PostgreSQL password for the main Julep database (memory-store)
# Set to any secure password of your choice
MEMORY_STORE_PASSWORD=<your_memory_store_password>

# PostgreSQL password for the Temporal workflow engine database
# Set to any secure password of your choice
TEMPORAL_POSTGRES_PASSWORD=<your_temporal_postgres_password>

# PostgreSQL password for LiteLLM's database (stores LLM routing config)
# Set to any secure password of your choice
LITELLM_POSTGRES_PASSWORD=<your_litellm_postgres_password>

# Redis password for LiteLLM's caching layer
# Set to any secure password of your choice
LITELLM_REDIS_PASSWORD=<your_litellm_redis_password>

# LLM Provider (at least one required)
# ------------------------------------

# OpenAI API key for GPT models and embeddings
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<your_openai_api_key>

# =============================================================================
# CONFIGURATION VARIABLES (with defaults)
# =============================================================================
# These have sensible defaults but can be customized.

# Agents API
# ----------

# Hostname where the Agents API is accessible
# Default: localhost (change for production deployments)
AGENTS_API_HOSTNAME=localhost

# Protocol for Agents API (http or https)
# Default: http (use https for production with SSL)
AGENTS_API_PROTOCOL=http

# HTTP header name used to pass the API key in requests
# Default: Authorization (standard auth header)
AGENTS_API_KEY_HEADER_NAME=Authorization

# Internal URL for the Agents API service (used by other services)
# Default points to the multi-tenant API container
AGENTS_API_URL=http://agents-api-multi-tenant:8080

# Enable debug mode for verbose logging
# Set to "true" for development troubleshooting
AGENTS_API_DEBUG=false

# Embedding Configuration
# -----------------------

# Model ID for generating text embeddings (used for semantic search)
# Options: "openai/text-embedding-3-large", "voyage/voyage-3", "Alibaba-NLP/gte-large-en-v1.5"
# OpenAI requires OPENAI_API_KEY, Voyage requires VOYAGE_API_KEY
EMBEDDING_MODEL_ID=openai/text-embedding-3-large

# Whether to truncate text that exceeds the embedding model's context limit
# Set to "true" to avoid errors with long texts
TRUNCATE_EMBED_TEXT=true

# Performance Settings
# --------------------

# Number of GPUs available for model inference
# Set to 0 for CPU-only deployments
NUM_GPUS=1

# Fraction of GPU memory to use (0.0 to 1.0)
# Lower values leave room for other processes
GPU_MEMORY_UTILIZATION=0.80

# Maximum number of sessions allowed in free tier
# Set higher for development/testing
MAX_FREE_SESSIONS=50

# Maximum number of task executions allowed in free tier
MAX_FREE_EXECUTIONS=50

# Storage Settings
# ----------------

# Internal URL for the integrations service
INTEGRATION_SERVICE_URL=http://integrations:8000

# Whether to store large Temporal payloads in blob storage (S3/SeaweedFS)
# Recommended for production to avoid Temporal payload size limits
USE_BLOB_STORE_FOR_TEMPORAL=true

# Minimum payload size (KB) before storing in blob storage
# Payloads smaller than this are stored directly in Temporal
BLOB_STORE_CUTOFF_KB=1024

# S3 bucket name for storing blobs
BLOB_STORE_BUCKET=agents-api

# Directory for mounting persistent data volumes
MNT_DIR=/data

# Skip developer header validation (set to true for single-tenant mode)
# In multi-tenant mode, set to false for proper authentication
SKIP_CHECK_DEVELOPER_HEADERS=true

# Worker
# ------

# URL for the Temporal worker to connect to
WORKER_URL=temporal:7233

# Memory Store
# ------------

# Timezone for Metabase (analytics dashboard)
# Use your local timezone in IANA format
# MB_JAVA_TIMEZONE=Asia/Calcutta

# Gateway
# -------

# Port for the API gateway (Traefik)
# Default: 80 (use 443 for HTTPS in production)
GATEWAY_PORT=80

# Traefik logging level (DEBUG, INFO, WARN, ERROR)
# Use DEBUG for troubleshooting, INFO for production
TRAEFIK_LOG_LEVEL=INFO

# Temporal
# --------

# Temporal server endpoint for workflow orchestration
TEMPORAL_ENDPOINT=temporal:7233

# Temporal namespace for isolating workflows
# Default: "default" (create custom namespaces for multi-tenancy)
TEMPORAL_NAMESPACE=default

# Temporal worker connection URL
TEMPORAL_WORKER_URL=temporal:7233

# PostgreSQL database name for Temporal
TEMPORAL_POSTGRES_DB=temporal

# PostgreSQL username for Temporal
TEMPORAL_POSTGRES_USER=temporal

# Maximum time (seconds) for a workflow to complete
# Increase for long-running tasks
TEMPORAL_SCHEDULE_TO_CLOSE_TIMEOUT=3600

# Custom search attribute key for filtering workflows
TEMPORAL_SEARCH_ATTRIBUTE_KEY=CustomStringField

# LiteLLM
# -------

# LiteLLM proxy URL for routing LLM requests
# Acts as a unified interface for multiple LLM providers
# LITELLM_URL=http://litellm:4000

# PostgreSQL database name for LiteLLM
LITELLM_POSTGRES_DB=litellm

# PostgreSQL username for LiteLLM
LITELLM_POSTGRES_USER=llmproxy

# Redis hostname for LiteLLM caching
LITELLM_REDIS_HOST=litellm-redis

# Redis port for LiteLLM
LITELLM_REDIS_PORT=6379

# Master API key for LiteLLM admin operations
# Generate with: openssl rand -base64 32
LITELLM_MASTER_KEY=<your_litellm_master_key>

# Salt key for hashing sensitive data in LiteLLM
# Generate with: openssl rand -base64 32
LITELLM_SALT_KEY=<your_litellm_salt_key>

# Redis startup arguments (sets the password requirement)
REDIS_ARGS="--requirepass ${LITELLM_REDIS_PASSWORD}"

# Grafana
# -------

# Grafana admin username for the monitoring dashboard
# Access at: http://localhost:3000 (default Grafana port)
GRAFANA_ADMIN_USER=<your_grafana_admin_user>

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=<your_grafana_admin_password>

# Blob Store
# ----------

# S3-compatible endpoint URL (SeaweedFS, MinIO, or AWS S3)
# Default points to local SeaweedFS container
# S3_ENDPOINT=http://seaweedfs:8333

# S3 access key ID for blob storage authentication
# For SeaweedFS: use any value, for AWS: get from IAM console
S3_ACCESS_KEY=<your_s3_access_key>

# S3 secret access key for blob storage authentication
S3_SECRET_KEY=<your_s3_secret_key>

# Integrations Service
# --------------------

# Port for the integrations service (handles external tool connections)
INTEGRATIONS_SERVICE_PORT=8000

# Feature Flags
# -------------

# Unleash server URL for feature flag management
# Unleash controls gradual feature rollouts
UNLEASH_URL=http://unleash:4242/api

# API token for authenticating with Unleash
# Get from: Unleash Admin UI > API Access
UNLEASH_API_TOKEN=<unleash_api_token>

# Application name registered in Unleash
UNLEASH_APP_NAME=agents-api

# Enable/disable the Responses API feature
# Set to "true" to enable response streaming
ENABLE_RESPONSES=false

# GraphQL (Hasura)
# ----------------

# Hasura GraphQL engine URL for database queries
HASURA_URL=http://hasura:8080

# JWT claims mapping for Hasura authorization
# Maps JWT token claims to Hasura permission variables
HASURA_CLAIMS_MAP='{"x-hasura-allowed-roles":{"path":"$.hasura.all_roles","default":["user"]},"x-hasura-default-role":{"path":"$.hasura.all_roles[0]","default":"user"},"x-hasura-user-id":{"path":"$.sub"}}'

# Hasura admin secret for full database access
# Generate with: openssl rand -base64 32
HASURA_ADMIN_SECRET=<your_hasura_admin_secret>

# Allowed clock skew (seconds) when validating JWT tokens
# Set higher if experiencing token expiration issues
JWT_ALLOWED_SKEW=0

# Llama Model Multiplier
# ----------------------

# Cost multiplier for Llama model usage tracking (0-100)
# Adjusts how Llama model costs are calculated
LLAMA_MODEL_MULTIPLIER=1.0

# =============================================================================
# OPTIONAL ENVIRONMENT VARIABLES
# =============================================================================
# These are only needed for specific features or integrations.
# Only configure the services you plan to use.

# Additional LLM Providers
# ------------------------

# Anthropic API key for Claude models (claude-3-opus, claude-3-sonnet, etc.)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Groq API key for fast inference (llama, mixtral models)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=<your_groq_api_key>

# Voyage AI API key for embeddings (voyage-3, voyage-code-3)
# Get from: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=<your_voyage_api_key>

# Cerebras API key for fast inference
# Get from: https://cloud.cerebras.ai/platform/api-keys
CEREBRAS_API_KEY=<your_cerebras_api_key>

# Google Gemini API key for Gemini models
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your_gemini_api_key>

# OpenRouter API key for accessing multiple LLM providers through one API
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=<your_openrouter_api_key>

# DeepSeek API key for DeepSeek models (deepseek-chat, deepseek-coder)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=<your_deepseek_api_key>

# Llama API key for Meta's Llama models hosted service
# Get from: https://www.llama-api.com/
LLAMA_API_KEY=<your_llama_api_key>

# AWS Bedrock API key (base64 encoded credentials)
# Get from: AWS Console > IAM > Security credentials
# Format: Base64 encoded "BedrockAPIKey-{region}-{timestamp}:{access_key}:{secret_key}"
BEDROCK_API_KEY=<your_bedrock_api_key>

# NVIDIA NIM API key for NVIDIA-hosted models
# Get from: https://build.nvidia.com/explore/discover (click "Get API Key")
NVIDIA_NIM_API_KEY=<your_nvidia_nim_api_key>

# GitHub API key (Personal Access Token) for GitHub integrations
# Get from: https://github.com/settings/tokens
GITHUB_API_KEY=<your_github_api_key>

# Cloudflare API key for Cloudflare Workers AI
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=<your_cloudflare_api_key>

# Cloudflare Account ID (required with CLOUDFLARE_API_KEY)
# Get from: https://dash.cloudflare.com/ (right sidebar on overview page)
CLOUDFLARE_ACCOUNT_ID=<your_cloudflare_account_id>

# Path to Google Cloud service account JSON file (for Vertex AI)
# Get from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download the JSON key file and provide the path
GOOGLE_APPLICATION_CREDENTIALS=<path_to_google_credentials_json>

# Hugging Face
# ------------

# Hugging Face API token for accessing models and datasets
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=<your_hugging_face_token>

# Alternative Hugging Face token variable (some libraries use this)
HUGGING_FACE_HUB_TOKEN=<your_hugging_face_hub_token>

# AWS Credentials
# ---------------

# AWS Access Key ID for AWS services (Bedrock, etc.)
# Get from: AWS Console > IAM > Users > Security credentials
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>

# AWS Secret Access Key (paired with Access Key ID)
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>

# AWS Session Token (only needed for temporary credentials/assumed roles)
# AWS_SESSION_TOKEN=<your_aws_session_token>

# AWS Region for services (e.g., us-east-1, eu-west-1)
# AWS_REGION_NAME=us-east-1

# Third-Party Integration Keys
# ----------------------------

# Browser Automation (Browserbase)
# --------------------------------

# Browserbase API key for cloud browser automation
# Get from: https://www.browserbase.com/settings (API Keys section)
BROWSERBASE_API_KEY=<your_browserbase_api_key>

# Browserbase Project ID for organizing browser sessions
# Get from: https://www.browserbase.com/settings (Projects section)
BROWSERBASE_PROJECT_ID=<your_browserbase_project_id>

# Web Scraping & Search
# ---------------------

# Spider API key for web scraping and crawling
# Get from: https://spider.cloud/account (after sign up)
SPIDER_API_KEY=<your_spider_api_key>

# Brave Search API key for web search integration
# Get from: https://brave.com/search/api/ (subscribe to get key)
BRAVE_API_KEY=<your_brave_api_key>

# RapidAPI key for accessing various APIs (Instagram, etc.)
# Get from: https://rapidapi.com/developer/dashboard (Your Apps > Security)
RAPID_API_KEY=<your_rapid_api_key>

# RapidAPI host for specific API endpoint
# Find on the specific API page on RapidAPI
RAPID_API_HOST=instagram-scraper-api2.p.rapidapi.com

# Weather
# -------

# OpenWeatherMap API key for weather data
# Get from: https://home.openweathermap.org/api_keys (free tier available)
OPENWEATHERMAP_API_KEY=<your_openweathermap_api_key>

# Media & Cloud Services
# ----------------------

# Cloudinary API key for image/video management
# Get from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_API_KEY=<your_cloudinary_api_key>

# Cloudinary API secret (paired with API key)
# Get from: Same page as API key
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>

# Cloudinary cloud name (your account identifier)
# Get from: https://console.cloudinary.com/settings/account (Cloud name field)
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>

# Email
# -----

# Mailgun API key or SMTP password for sending emails
# Get from: https://app.mailgun.com/app/account/security/api_keys
MAILGUN_PASSWORD=<your_mailgun_password>

# Google Sheets Integration
# -------------------------

# Base64-encoded Google Service Account JSON for Sheets API access
# 1. Create service account: https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Download JSON key file
# 3. Encode with: base64 -w 0 service-account.json
JULEP_GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=<base64_encoded_service_account_json>

# Social Media
# ------------

# Twitter/X Bearer Token for API v2 access (read-only)
# Get from: https://developer.twitter.com/en/portal/dashboard (App > Keys and tokens)
TWITTER_BEARER_TOKEN=<your_twitter_bearer_token>

# Twitter/X API Key (Consumer Key) for OAuth 1.0a
# Get from: Same page as Bearer Token
TWITTER_API_KEY=<your_twitter_api_key>

# Twitter/X API Key Secret (Consumer Secret)
# Get from: Same page as Bearer Token
TWITTER_API_KEY_SECRET=<your_twitter_api_key_secret>

# Text Humanization / AI Detection
# --------------------------------
# Only needed for humanize_text method in evaluate step.

# Sapling API key for AI text detection and grammar checking
# Get from: https://sapling.ai/user/settings (after creating account)
SAPLING_API_KEY=<your_sapling_api_key>

# Copyleaks API key for plagiarism and AI content detection
# Get from: https://api.copyleaks.com/ (Dashboard > API Keys)
COPYLEAKS_API_KEY=<your_copyleaks_api_key>

# Monitoring & Observability
# --------------------------

# Sentry DSN for error tracking in the main Agents API
# Get from: https://sentry.io/ > Project Settings > Client Keys (DSN)
SENTRY_DSN=<your_sentry_dsn>

# Sentry DSN for the Integrations Service (separate project recommended)
INTEGRATIONS_SENTRY_DSN=<your_integrations_sentry_dsn>

# Portainer admin username for container management UI
# Access at: https://localhost:9443 (default Portainer port)
PORTAINER_ADMIN_USER=<your_portainer_admin_user>

# Portainer admin password (set on first login if not provided)
PORTAINER_ADMIN_PASSWORD=<your_portainer_admin_password>

# Temporal Fine Tuning
# --------------------
# Uncomment and adjust these for performance optimization.

# Maximum concurrent workflow tasks per worker
# TEMPORAL_MAX_CONCURRENT_WORKFLOW_TASKS=

# Maximum concurrent activities per worker (default: unlimited)
# Lower this if experiencing memory issues
# TEMPORAL_MAX_CONCURRENT_ACTIVITIES=100

# Maximum activities started per second (rate limiting)
# TEMPORAL_MAX_ACTIVITIES_PER_SECOND=

# Maximum activities per second per task queue
# TEMPORAL_MAX_TASK_QUEUE_ACTIVITIES_PER_SECOND=

# Timeout (seconds) before retrying a failed activity
# TEMPORAL_ACTIVITY_AFTER_RETRY_TIMEOUT=30

# Rate limit for transition requests per minute
# AGENTS_API_TRANSITION_REQUESTS_PER_MINUTE=500
